{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "files": {
    "includes": [
      "src/**/*.ts",
      "scripts/**/*.js",
      "bin/**/*.js",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/coverage",
      "!!**/build",
      "!!**/assets",
      "!!**/personas",
      "!!**/.idea",
      "!!**/.github",
      "!!**/docs",
      "!!**/package-lock.json"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsole": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn",
        "noUnusedFunctionParameters": "off"
      },
      "style": {
        "useImportType": "warn",
        "useExportType": "warn",
        "noParameterAssign": "off",
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off",
        "useTemplate": "warn"
      }
    }
  },
  "javascript": {
    "globals": ["NodeJS"]
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
