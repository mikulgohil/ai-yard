{
  "name": "@mikulgohil/ai-yard",
  "version": "0.2.35",
  "publishConfig": {
    "access": "public"
  },
  "description": "A terminal-centric IDE for AI-powered CLI tools, built on Electron",
  "author": {
    "name": "Mikul Gohil",
    "email": "mikulgohil@outlook.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikulgohil/ai-yard.git"
  },
  "homepage": "https://github.com/mikulgohil/ai-yard",
  "bugs": {
    "url": "https://github.com/mikulgohil/ai-yard/issues"
  },
  "bin": {
    "ai-yard": "bin/ai-yard.js"
  },
  "keywords": [
    "electron",
    "ide",
    "terminal",
    "claude",
    "claude-code",
    "ai",
    "developer-tools"
  ],
  "files": [
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/main/main/main.js",
  "scripts": {
    "build": "npm run gen-build-config && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && npm run build:renderer",
    "build:renderer": "npm run copy-vite-public && vite build --config vite.renderer.config.ts",
    "build:renderer:legacy": "esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/index.js --platform=browser --format=iife --target=es2022 --sourcemap --loader:.ts=ts --minify-syntax --minify-whitespace --legal-comments=none && npm run copy-assets",
    "build:legacy": "npm run gen-build-config && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && npm run build:renderer:legacy",
    "copy-assets": "node scripts/copy-assets.js",
    "copy-vite-public": "node scripts/copy-vite-public.js",
    "gen-build-config": "node scripts/gen-build-config.js",
    "start": "npm run build && electron .",
    "dev": "npm run gen-build-config && npm run copy-vite-public && concurrently -k -n main,preload,renderer,electron \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"tsc -p tsconfig.preload.json --watch --preserveWatchOutput\" \"vite --config vite.renderer.config.ts\" \"wait-on http://localhost:5173 file:dist/main/main/main.js file:dist/preload/preload/preload.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:legacy": "npm run build:legacy && electron .",
    "postinstall": "node -e \"try{require('electron-builder/package.json');require('child_process').execSync('electron-builder install-app-deps',{stdio:'inherit'})}catch{}\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "npm run gen-build-config && vitest run",
    "test:watch": "npm run gen-build-config && vitest",
    "test:coverage": "npm run gen-build-config && vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test:e2e": "npm run build && playwright test"
  },
  "build": {
    "appId": "com.aiyard.app",
    "productName": "AI-yard",
    "icon": "build/icon.png",
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@types/picomatch": "^4.0.2",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sentry/electron": "^7.13.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.8.3",
    "gridstack": "^12.6.0",
    "marked": "^17.0.5",
    "node-pty": "^1.1.0",
    "picomatch": "^4.0.3"
  }
}
